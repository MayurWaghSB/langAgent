{
  "name": "senior-engineer-agent",
  "version": "0.1.0",
  "description": "A LangChain/LangGraph agent that codes like a senior software engineer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "senior-engineer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "ai",
    "agent",
    "code-generation",
    "senior-engineer"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.44",
    "@langchain/groq": "^0.2.3",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/openai": "^0.5.10",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
